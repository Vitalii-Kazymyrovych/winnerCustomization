{
  "sourceDatabase": {
    "host": "SOURCE_DB_HOST",
    "port": 5432,
    "db": "source_database_name",
    "schema": "videoanalytics",
    "user": "source_user",
    "password": "source_password"
  },
  "sequenceDatabase": {
    "host": "SEQUENCE_DB_HOST",
    "port": 5432,
    "db": "sequences_database_name",
    "schema": "public",
    "user": "sequence_user",
    "password": "sequence_password"
  },
  "rootDatabase": {
    "host": "SEQUENCE_DB_HOST",
    "port": 5432,
    "user": "postgres_root_user",
    "password": "postgres_root_password",
    "maintenanceDb": "postgres"
  },
  "sourceTable": {
    "table": "alpr_detections",
    "loadFrom": "2026-03-17T00:00:00"
  },
  "notifications": {
    "enabled": false,
    "telegramBotToken": "BOT_TOKEN_IF_ENABLED",
    "telegramChatId": "CHAT_ID_IF_ENABLED"
  },
  "timing": {
    "driveInToDriveOutAlertMinutes": 15,
    "serviceToPostAlertMinutes": 15,
    "testDriveStartMinutes": 30,
    "testDriveResetMinutes": 60
  },
  "cameras": {
    "driveInIn": [
      {
        "name": "Drive in (in) cam 1",
        "analyticsId": 1001,
        "directionRange": {
          "from": null,
          "to": null
        }
      }
    ],
    "driveInOut": [
      {
        "name": "Drive in (out) cam 1",
        "analyticsId": 1002,
        "directionRange": {
          "from": 0,
          "to": 180
        }
      }
    ],
    "driveInToService": [
      {
        "name": "Drive-In -> Service",
        "analyticsId": 1008,
        "directionRange": {
          "from": null,
          "to": null
        }
      }
    ],
    "serviceIn": [
      {
        "name": "Service (in) cam 1",
        "analyticsId": 1003,
        "directionRange": {
          "from": null,
          "to": null
        }
      }
    ],
    "servicePosts": [
      {
        "postName": "Post 1",
        "analyticsId": 1101,
        "inDirectionRange": {
          "from": 0,
          "to": 180
        },
        "outDirectionRange": {
          "from": 181,
          "to": 360
        }
      }
    ],
    "serviceOut": [
      {
        "name": "Service (out)",
        "analyticsId": 1005,
        "directionRange": {
          "from": null,
          "to": null
        }
      }
    ],
    "serviceToDriveIn": [
      {
        "name": "Service -> Drive-In",
        "analyticsId": 1009,
        "directionRange": {
          "from": null,
          "to": null
        }
      }
    ],
    "parkingIn": [
      {
        "name": "Parking (in)",
        "analyticsId": 1006,
        "directionRange": {
          "from": null,
          "to": null
        }
      }
    ],
    "parkingOut": [
      {
        "name": "Parking (out)",
        "analyticsId": 1007,
        "directionRange": {
          "from": null,
          "to": null
        }
      }
    ]
  },
  "reports": {
    "outputDirectory": "./reports"
  },
  "workflow": {
    "defaultSequenceCloseTimeoutMinutes": 2880,
    "stages": [
      {
        "name": "drive_in",
        "labelTemplate": "Drive In",
        "allowPartialFromFinish": true,
        "startTriggers": [
          {
            "cameraId": 1001,
            "eventType": "in",
            "eventKey": "DRIVE_IN_IN",
            "notification": {
              "enabled": true,
              "template": "No Drive in (out) within {{threshold}} minutes",
              "delayMinutes": 15
            }
          }
        ],
        "finishTriggers": [
          {
            "cameraId": 1002,
            "directionRange": {
              "from": 0,
              "to": 180
            },
            "eventType": "out",
            "eventKey": "DRIVE_IN_OUT"
          }
        ]
      },
      {
        "name": "service",
        "labelTemplate": "Service",
        "allowPartialFromFinish": true,
        "intermediateStageOnTransition": "backyard",
        "startTriggers": [
          {
            "cameraId": 1003,
            "eventType": "in",
            "eventKey": "SERVICE_IN",
            "notification": {
              "enabled": true,
              "template": "No Post in within {{threshold}} minutes",
              "delayMinutes": 15
            }
          }
        ],
        "finishTriggers": [
          {
            "cameraId": 1005,
            "eventType": "out",
            "eventKey": "SERVICE_OUT"
          }
        ]
      },
      {
        "name": "post_1",
        "labelTemplate": "Post 1",
        "finishMode": "sticky",
        "allowPartialFromFinish": true,
        "timeoutTransitionToStage": "service",
        "startTriggers": [
          {
            "cameraId": 1101,
            "directionRange": {
              "from": 0,
              "to": 180
            },
            "eventType": "in",
            "eventKey": "POST_1_IN",
            "derivedStageInstance": "1"
          }
        ],
        "finishTriggers": [
          {
            "cameraId": 1101,
            "directionRange": {
              "from": 181,
              "to": 360
            },
            "eventType": "out",
            "eventKey": "POST_1_OUT",
            "derivedStageInstance": "1"
          }
        ]
      },
      {
        "name": "parking",
        "labelTemplate": "Parking",
        "allowPartialFromFinish": true,
        "intermediateStageOnTransition": "backyard",
        "startTriggers": [
          {
            "cameraId": 1006,
            "eventType": "in",
            "eventKey": "PARKING_IN"
          }
        ],
        "finishTriggers": [
          {
            "cameraId": 1007,
            "eventType": "out",
            "eventKey": "PARKING_OUT"
          }
        ]
      },
      {
        "name": "backyard",
        "labelTemplate": "Backyard",
        "transitional": true,
        "saveStageAfterSequenceClosed": false,
        "startTriggers": [
          {
            "cameraId": 1008,
            "eventType": "in",
            "eventKey": "DRIVE_IN_TO_SERVICE"
          }
        ]
      },
      {
        "name": "test_drive",
        "labelTemplate": "Test-Drive",
        "startMode": "candidate",
        "candidateTimeoutMinutes": 30,
        "candidateCloseTimeoutMinutes": 60,
        "saveStageAfterSequenceClosed": false,
        "startTriggers": [
          {
            "cameraId": 1002,
            "directionRange": {
              "from": 0,
              "to": 180
            },
            "eventType": "candidate",
            "eventKey": "DRIVE_IN_OUT"
          },
          {
            "cameraId": 1009,
            "eventType": "candidate",
            "eventKey": "SERVICE_TO_DRIVE_IN"
          }
        ]
      }
    ]
  }
}
